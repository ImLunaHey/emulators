{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "gba-recomp",
  "compatibility_date": "2026-06-08",
  "main": "src/worker.ts",
  "observability": {
    "enabled": true
  },
  "assets": {
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
