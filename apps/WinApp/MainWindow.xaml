<Window x:Class="EmuWin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="imlunahey emulator" Height="640" Width="960"
        Background="Black"
        UseLayoutRounding="True">
    <DockPanel>
        <Border x:Name="TopBar" DockPanel.Dock="Top" Padding="8,6">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="OpenBtn" Content="Open ROM…" Click="OpenRom_Click" Margin="0,0,8,0"/>
                <TextBlock x:Name="TitleText" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <Button x:Name="PauseBtn" Content="Pause" Click="Pause_Click" Visibility="Collapsed" Margin="8,0,0,0"/>
                <Button x:Name="ResetBtn" Content="Reset" Click="Reset_Click" Visibility="Collapsed" Margin="8,0,0,0"/>
                <Button x:Name="StopBtn" Content="Stop" Click="Stop_Click" Visibility="Collapsed" Margin="8,0,0,0"/>
                <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Volume" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Slider x:Name="VolumeSlider" Width="110" Minimum="0" Maximum="1" Value="1"
                            VerticalAlignment="Center" ValueChanged="Volume_Changed"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid>
            <Image x:Name="Screen" Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
            <StackPanel x:Name="HomePanel" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="imlunahey emulator" FontSize="22" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Open a ROM, or pick a recent game below."
                           Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <ListBox x:Name="RecentsList" Width="380" MaxHeight="340"
                         MouseDoubleClick="Recent_DoubleClick"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
