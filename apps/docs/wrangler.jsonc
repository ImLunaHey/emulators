{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "emulators-docs",
  "compatibility_date": "2026-06-08",
  // Assets-only deploy: no `main` Worker script. Cloudflare serves the built
  // SPA from ./dist directly, falling back to index.html for client-side
  // routes (e.g. /core/gba) on a hard refresh.
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
