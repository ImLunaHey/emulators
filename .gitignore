# rust build artifacts (every crate's target/ + wasm-pack pkg/ output, anywhere;
# built in CI + locally, never committed). Blanket globs so new cores don't each
# need their own entry.
**/target/
**/pkg/

# rust mobile FFI crate (native libs / xcframework build output)
core-ffi/build
core-ffi/Cargo.lock
**/*.rs.bk

# swift package / native app build output
.build/
apps/**/.build/

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example
