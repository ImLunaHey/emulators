node_modules
dist
.vite
.DS_Store
*.log
_*.png
tsconfig.tsbuildinfo
coverage

# ROM / disc-image dumps — never commit commercial dumps
*.gba
*.sav
*.bin
*.cue
*.nds
# ...except the open-source PS1 BIOS (PCSX-Redux OpenBIOS, redistributable),
# which the web app bundles through Vite's asset pipeline.
!apps/web/src/assets/openbios.bin
public/*.gba
public/*.sav
public/*.bin
public/*.cue

# rust build artifacts (every crate's target/ + wasm-pack pkg/ output, anywhere;
# built in CI + locally, never committed). Blanket globs so new cores don't each
# need their own entry.
**/target/
**/pkg/

# rust mobile FFI crate (native libs / xcframework build output)
packages/ffi/build
packages/ffi/Cargo.lock
**/*.rs.bk

# turborepo cache
.turbo
**/.turbo

# swift package / native app build output
.build/
apps/**/.build/

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example
