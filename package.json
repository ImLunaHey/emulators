{
  "name": "gba-recomp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "portless": "emulators",
  "scripts": {
    "dev": "vite",
    "dev:portless": "portless emulators vite",
    "build:wasm": "wasm-pack build core --target web --out-dir pkg --release",
    "build:wasm:nds": "wasm-pack build core-nds --target web --out-dir pkg --release",
    "build:wasm:ps1": "wasm-pack build core-ps1 --target web --out-dir pkg --release",
    "build:wasm:nes": "wasm-pack build core-nes --target web --out-dir pkg --release",
    "build:wasm:sms": "wasm-pack build core-sms --target web --out-dir pkg --release",
    "build:wasm:gbc": "wasm-pack build core-gbc --target web --out-dir pkg --release",
    "build:wasm:xbox": "wasm-pack build core-xbox --target web --out-dir pkg --release",
    "build": "tsc && vite build",
    "preview": "npm run build && wrangler dev",
    "gen:cheats": "tsx scripts/gen-cheats.ts",
    "test": "cargo test --manifest-path core/Cargo.toml",
    "lint": "oxlint src",
    "deploy": "npm run build:wasm && npm run build:wasm:nds && npm run build:wasm:nes && npm run build:wasm:sms && npm run build:wasm:gbc && npm run build:wasm:ps1 && npm run build:wasm:xbox && npm run build && wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.0",
    "@cloudflare/workers-types": "^4.20260608.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "oxlint": "^1.68.0",
    "portless": "^0.13.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wrangler": "^4.98.0"
  },
  "dependencies": {
    "@tanstack/query-sync-storage-persister": "^5.101.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-persist-client": "^5.101.0",
    "fflate": "^0.8.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0"
  }
}
