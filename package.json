{
  "name": "emulators",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@emulators/web",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "deploy": "turbo run deploy --filter=@emulators/web",
    "gen:cheats": "tsx scripts/gen-cheats.ts"
  },
  "devDependencies": {
    "tsx": "^4.22.4",
    "turbo": "^2.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
